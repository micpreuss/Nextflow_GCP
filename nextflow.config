params {
  gcp_bucket = 'gs://northwell-nextflow'
  project_slug = 'nextflow-gcp'
  user = System.getenv('USER') ?: 'unknown-user'
}

profiles {
  test {
    process.executor = 'local'
    params.project = 'local'
    params.region = 'local'
    workDir = 'work'
    docker.enabled = true
  }
  
  gcp {
    process {
      executor = 'google-batch'
      machineType = 'e2-standard-2'
      disk = '10 GB'
      errorStrategy = 'retry'
      maxRetries = 3
    }

    workDir = "${params.gcp_bucket}/${params.project_slug}/work/${params.user}"
    outputDir = "${params.gcp_bucket}/${params.project_slug}/results/${params.user}"

    docker {
      enabled = true
    }
  }
}

google {
  project = 'lencz-lab-cogent-1'
  location = 'us-east1'
  batch {
    spot = true              // ← this is the big money saver
  }
}

process {
  executor = 'local'
  cpus = 1
  memory = '1 GB'
  time = '1h'
}

